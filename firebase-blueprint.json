{
  "entities": {
    "UserProgress": {
      "title": "UserProgress",
      "description": "Stores the learning progress of a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "completedLessons": { "type": "array", "items": { "type": "string" }, "description": "List of completed lesson IDs." },
        "examScores": { "type": "object", "description": "Scores for different exams." },
        "totalProgress": { "type": "number", "description": "Overall progress percentage." },
        "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"], "description": "Current proficiency level." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["uid", "completedLessons", "totalProgress", "level"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProgress",
      "description": "User profile and progress data."
    }
  }
}
