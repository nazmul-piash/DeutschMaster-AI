rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL BY DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Profile Validation
    function isValidProfile(data) {
      return data.keys().hasAll(['completed_lessons', 'exam_scores', 'total_progress', 'level']) &&
             data.completed_lessons is list &&
             data.exam_scores is map &&
             data.total_progress is number &&
             data.level in ['A1', 'A2'];
    }

    match /profiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data) &&
                      (request.resource.data.diff(resource.data).affectedKeys().hasAny(['completed_lessons', 'exam_scores', 'total_progress', 'level', 'updated_at']));
    }
  }
}
